{
  "name": "strawberry-browser",
  "version": "1.0.0",
  "description": "Strawberry AI Browser - An agentic browser with AI companions",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "htmlparser2": "^12.0.0",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.strawberry.browser",
    "productName": "Strawberry Browser",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "darkModeSupport": true
    },
    "dmg": {
      "title": "Strawberry Browser"
    }
  }
}
