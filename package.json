{
  "name": "yantra-browser",
  "version": "1.0.0",
  "description": "Yantra AI Browser - Production AI browser automation platform",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg",
    "test:smoke": "node test/smoke.js",
    "diagnose": "node -e \"const d=require('./main/ai/llmClient');console.log('llmClient loaded OK')\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "openai": "^4.0.0",
    "htmlparser2": "^12.0.0",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.yantra.browser",
    "productName": "Yantra",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "darkModeSupport": true
    },
    "dmg": {
      "title": "Yantra"
    }
  }
}
