# ── Yantra Environment Configuration ─────────────────────────────────────────
# Copy this file to .env and fill in real values. Never commit .env to git.

# ── AI Provider Keys ──────────────────────────────────────────────────────────
# At least one is required. Both enables automatic fallback.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Which provider to use first (anthropic | openai). Falls back to the other on overload.
PREFERRED_PROVIDER=anthropic

# ── Yantra Backend API ────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# JWT secret — generate with: openssl rand -base64 48
JWT_SECRET=replace_with_64_char_random_string

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://yantra:yantra_dev@localhost:5432/yantra
POSTGRES_PASSWORD=yantra_dev

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Stripe (billing) ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs for each plan
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_TEAM_MONTHLY=price_...

# ── AWS (optional — for S3 audit logs, SES email) ─────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AUDIT_S3_BUCKET=yantra-audit-logs

# ── Feature flags ─────────────────────────────────────────────────────────────
ENABLE_BILLING=false
ENABLE_TEAMS=false
